# ==========================================
# 1. БАЗА ДАННЫХ (PostgreSQL)
# ==========================================
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123admin
POSTGRES_DB=media_db
DATABASE_URL=postgresql://admin:password123admin@db:5432/media_db

# ==========================================
# 2. ОЧЕРЕДЬ ЗАДАЧ (RabbitMQ)
# ==========================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=adminpassword123
# Формат: amqp://пользователь:пароль@хост:порт/
RABBITMQ_URL=amqp://admin:adminpassword123@queue:5672//

# ==========================================
# 3. ХРАНИЛИЩЕ ФАЙЛОВ (MinIO / S3)
# ==========================================
# MinIO по умолчанию использует эти ключи, лучше смените их для продакшена
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_ENDPOINT=http://storage:9000
S3_BUCKET=media-pipeline
# Регион не важен для MinIO, но нужен для совместимости
S3_REGION=us-east-1

# ==========================================
# 3. КОНФИГУРАЦИИ
# ==========================================
#папка на хосте, в которой источник типа FileSystem будет искать видео
FILESYSTEM_SOURCE_VIDEOS_FOLDER=/media/source_video

#лимит публикаций в день, ограничения платформ
PLATFORMS_CONFIG_PATH=platforms.yaml

#настройки нарезчиков
SEGMENTERS_CONFIG_PATH=segmenters.yaml

# ==========================================
# 4. ПРИЛОЖЕНИЕ И БЕЗОПАСНОСТЬ
# ==========================================
# Случайная строка для шифрования сессий и токенов
SECRET_KEY=super_secret_key_change_me_in_production
# Режим: development или production
APP_ENV=development

# ==========================================
# 5. ВНЕШНИЕ API
# ==========================================

#--------------YOUTUBE--------------
#Нужно для скачивания видео с Youtube, используется источниками типов YoutubeSearchAdapter, YoutubeChannelsAdapter
YOUTUBE_API_KEY=AIzaSyCaPKe6KP6iXIcLhxFLBpe2pEEhL6UXsqY
GOOGLE_CLIENT_ID=513687580361-sjpoblu6mth4u7o69e1sn9ioek4ungmc.apps.googleusercontent.com
#Нужно для публикации youtube-шортсов
GOOGLE_CREDENTIALS_PATH=/app/secrets/google_client_secret.json
GOOGLE_TOKEN_PATH=/app/secrets/token.pickle

